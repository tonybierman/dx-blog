# Copy to .env for local development. All values are optional in dev.

# --- Database -------------------------------------------------------------
# SQLite build (default): file at ./data/blog.db when unset.
# DATABASE_URL=sqlite://./data/blog.db?mode=rwc
#
# Postgres build (--no-default-features --features web,server,postgres):
# REQUIRED — no on-disk fallback. The pgcrypto extension is enabled by the
# init migration so gen_random_bytes() is available.
# DATABASE_URL=postgres://user:pass@localhost:5432/riparion

# --- Site (sitemap.xml / Atom feed) ---------------------------------------
# Canonical origin used to build absolute URLs in /sitemap.xml and /feed.xml.
# Defaults to http://localhost:3000 in dev; set to your real https origin.
# SITE_URL=https://blog.example.com
# Feed <title> (defaults to "riparion-cms").
# SITE_TITLE=riparion-cms

# --- Auth (arium) ---------------------------------------------------------
# DEV ONLY — never enable in production. Skips the email-verification
# round-trip so register logs you in immediately; with it on, *any* email is
# auto-confirmed (identity spoofing). Left commented so a promoted .env is safe.
# DX_AUTH_SKIP_EMAIL_VERIFICATION=1
# The first account that registers with this email is granted the admin role.
# DX_AUTH_BOOTSTRAP_ADMIN_EMAIL=you@example.com

# --- Email (optional; password reset / verification) ----------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAIL_FROM_ADDRESS=blog@example.com

# --- GitHub OAuth (optional) ----------------------------------------------
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Seed accounts --------------------------------------------------------
# DEV ONLY — never enable in production. Seeding plants demo posts/users on an
# empty DB. Off unless DX_SEED=1 is set explicitly (a release build that leaves
# this unset never seeds). Uncomment for local demo data.
# DX_SEED=1
# The seeded admin (admin@example.com) gets a random password printed once at
# startup unless you pin it here. The demo authors (ada@/linus@example.com) use
# the password "password". Never plant a known-password admin in any shared env.
# DX_SEED_ADMIN_PASSWORD=change-me
